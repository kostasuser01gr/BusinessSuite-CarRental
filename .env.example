# --- Backend (Railway/Production) ---
PORT=5000
NODE_ENV=production
# Generate a 32+ char secret: openssl rand -base64 32
SESSION_SECRET=your-32-char-minimum-production-secret-here
# The URL of your deployed frontend (e.g. https://adaptive-ai.vercel.app)
VITE_CLIENT_URL=http://localhost:3100
# Database (Future)
DATABASE_URL=postgresql://user:pass@host:5432/db

# --- Frontend (Vercel/Production) ---
# The URL of your deployed backend (e.g. https://adaptive-backend.up.railway.app)
VITE_API_URL=http://localhost:5000

# --- Local Development ---
# Copy these to .env for local dev
# VITE_API_URL=http://localhost:5000
# VITE_CLIENT_URL=http://localhost:3100
